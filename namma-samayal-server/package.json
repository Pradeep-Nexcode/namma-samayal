{
  "name": "namma-samayal-server",
  "version": "1.0.0",
  "description": "A Node.js server for Namma Samayal - Recipe management application",
  "keywords": [
    "recipe",
    "food",
    "nodejs",
    "express",
    "mongodb"
  ],
  "license": "MIT",
  "author": "Your Name",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec \"npm run build && node dist/server.js\"",
    "dev:ts": "nodemon --watch src --ext ts --exec \"node --loader ts-node/esm --experimental-specifier-resolution=node src/server.ts\"",
    "seed:admin": "node --loader ts-node/esm --experimental-specifier-resolution=node src/scripts/seedAdmin.ts",
    "test": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^7.2.0",
    "eslint": "^8.47.0",
    "jest": "^29.6.4",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
